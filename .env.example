# =====================================================
# Токсичный Ревизор — Конфигурация
# =====================================================

# [ОБЯЗАТЕЛЬНО] Telegram Bot Token (получить у @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# =====================================================
# LLM Provider — выберите один из двух вариантов
# Поддерживаемые значения: "gemini" или "openai"
# =====================================================
LLM_PROVIDER=gemini

# [Если LLM_PROVIDER=gemini] Google Gemini API Key
# Получить бесплатно: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# [Если LLM_PROVIDER=openai] OpenAI API Key
# Получить: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# =====================================================
# Дополнительные настройки (можно не трогать)
# =====================================================

# Максимальный размер фото для обработки (в пикселях по большей стороне)
MAX_IMAGE_SIZE=1600

# Температура генерации (0.0-2.0, выше = креативнее)
LLM_TEMPERATURE=1.0

# Максимум токенов в ответе
LLM_MAX_TOKENS=1500

# Логирование: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
